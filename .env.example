# ============================================================================
# Mailwave — example environment file. Copy to `.env.local` before `npm run dev`.
# Anything prefixed with VITE_ is exposed to the browser bundle, so never put
# a provider client secret here.
# ============================================================================

# ---------- Frontend (Vite) ----------
# Base URL of the backend API. The OAuth start endpoint lives at
# `${VITE_API_BASE_URL}/auth/google` (and similar for Facebook). When this is
# empty, the social Log In buttons surface
# "Google Log In is not configured yet."
VITE_API_BASE_URL=http://localhost:5000/api/v1

# Set to `true` ONLY in local development if you want the social buttons to
# resolve to a demo profile without a real backend. Even in mock mode the UI
# still routes through /auth/social-complete + /auth/verify-mobile-otp; the
# demo OTP code is 123456. Production builds must keep this false so the
# OAuth dance is always real.
VITE_ENABLE_MOCK_OAUTH=false

# ============================================================================
# Backend (NOT consumed by Vite). These belong in the backend's own .env file
# and are listed here only so the full OAuth contract is documented in one
# place. NEVER prefix them with VITE_.
# ============================================================================

# ---------- Google OAuth (passport-google-oauth20) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ---------- Facebook OAuth (passport-facebook) ----------
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:5000/api/v1/auth/facebook/callback

# ---------- App JWT signing ----------
JWT_SECRET=
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=
REFRESH_TOKEN_EXPIRES_IN=30d

# ---------- Contact Number OTP (SMS provider) ----------
# Any provider that accepts these env vars works (MSG91, Twilio, Plivo, etc.).
# OTPs must be 6 digits, hashed before persistence, expire in 5 minutes, with
# 30s resend cooldown and at most 5 verify attempts.
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER_ID=
